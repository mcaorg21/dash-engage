{
  "name": "dash-engage",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node --env-file-if-exists=.env.local --import tsx server/index.ts",
    "seed": "node --env-file-if-exists=.env.local --import tsx server/seed.ts",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "start:prod": "NODE_ENV=production tsx server/index.ts",
    "build:prod": "vite build && NODE_ENV=production tsx server/index.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.562.0",
    "pg": "^8.14.1",
    "tsx": "^4.19.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.14",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
